---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

import { Image } from 'astro:assets';
import placeholderImage from '../assets/jack.png'; 
---


<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="layout-duas-colunas">
				
				<div class="coluna-imagem">
					<Image 
						src={placeholderImage} 
						alt="Uma foto de exemplo" 
 
					/>				</div>

				<div class="coluna-texto">
					<h1> Oie! </h1>
					<p>
					Bem-vindo ao meu Blog e Portfolio, onde armazeno desenhos, artigos, códigos, e escrevo o que se passa na minha cabeça.
					</p>
					
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Configuração da caixa principal */
	.layout-duas-colunas {
		display: grid;
		/* 👇 A MÁGICA ACONTECE AQUI 👇 */
		grid-template-columns: 2fr 4fr; /* Imagem fica com 2/6 e texto com 4/6 */
		gap: 3rem; /* Espaço de respiro entre a imagem e o texto */
		align-items: center; /* Alinha os dois lados verticalmente no centro */
	}

	/* Garante que a imagem nunca vaze da coluna dela */
	.coluna-imagem img {
		width: 100%;
		height: auto;
		border-radius: 16px;
		box-shadow: var(--box-shadow); /* Usa a sombra padrão do template */
	}

	/* REGRA PARA CELULAR: Quando a tela for menor que 768px, muda para 1 coluna só */
	@media (max-width: 768px) {
		.layout-duas-colunas {
			grid-template-columns: 1fr; /* 1 única coluna */
			gap: 2rem;
			text-align: center; /* Centraliza o texto no celular (opcional, pode tirar se preferir) */
		}

		/* Faz a lista de itens ficar alinhada à esquerda mesmo com o texto centralizado no celular */
		.coluna-texto ul {
			text-align: left;
			display: inline-block;
		}
	}
</style>